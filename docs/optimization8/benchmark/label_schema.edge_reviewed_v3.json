{
  "schema_name": "optimization8_edge_label_reviewed_v3",
  "required_top_level_fields": [
    "schema_version",
    "case_id",
    "source_video_path",
    "label_source_preprocess_dirs",
    "seed_reviewed_dataset_dir",
    "label_status",
    "review_metadata",
    "preprocess_frame_index",
    "source_frame_index",
    "export_shape",
    "difficulty_score",
    "annotations",
    "category_presence"
  ],
  "required_annotations": {
    "hard_foreground": "grayscale png",
    "soft_alpha": "grayscale png",
    "trimap_unknown": "grayscale png",
    "boundary_mask": "grayscale png",
    "occlusion_band": "grayscale png",
    "uncertainty_map": "grayscale png",
    "boundary_type_map": "indexed grayscale png",
    "face_boundary_mask": "grayscale png",
    "hair_edge_mask": "grayscale png",
    "hand_boundary_mask": "grayscale png",
    "cloth_boundary_mask": "grayscale png",
    "semi_transparent_boundary_mask": "grayscale png"
  },
  "boundary_type_values": {
    "0": "non-boundary",
    "1": "face",
    "2": "hair",
    "3": "hand",
    "4": "cloth",
    "5": "occluded",
    "6": "semi_transparent"
  },
  "allowed_label_status": [
    "reviewed_consensus_v3_candidate"
  ],
  "review_metadata_fields": [
    "reviewer",
    "review_status",
    "review_mode",
    "review_notes",
    "review_tier",
    "revision_strength",
    "split",
    "seed_source",
    "initial_auto_label_sources"
  ]
}
