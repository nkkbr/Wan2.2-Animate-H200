        "foreground_patch",
        "background_patch",
        "input_soft_alpha",
        "input_boundary_roi_mask",
        "input_person_mask"
      ],
      "required_targets": [
        "gt_soft_alpha",
        "gt_boundary_mask",
        "gt_occlusion_band"
      ],
      "primary_metrics": [
        "boundary_f1",
        "alpha_mae",
        "halo_proxy"
      ]
    }
  ],
